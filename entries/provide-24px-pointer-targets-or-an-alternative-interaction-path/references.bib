@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{fivethirtyeight_how_house,
  title = {How the House Got Stuck at 435 Seats -- FiveThirtyEight},
  howpublished = {\url{https://projects.fivethirtyeight.com/435-representatives/}},
  note = {This interactive project examines how the U.S. House of Representatives has remained fixed at 435 seats since 1910. It uses visualizations and simulations to show how apportionment works, highlighting that population growth and fixed seats create inequities in representation and exploring proposals for expanding the House:contentReference[oaicite:31]\{index=31\}:contentReference[oaicite:32]\{index=32\}.}
}
@misc{w3c_understanding_target,
  author = {W3C},
  title = {Understanding Target Size (Minimum) -- WCAG~2.2},
  howpublished = {\url{https://www.w3.org/WAI/WCAG22/Understanding/target-size-minimum.html}},
  note = {The target size criterion states that interactive elements activated via pointer input should be at least 24~$\times$~24~CSS pixels. Alternatively, equivalent spacing or another control can be provided. This ensures controls are large enough for users with limited dexterity:contentReference[oaicite:33]\{index=33\}.}
}