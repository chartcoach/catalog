@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{datawrapper_how_your,
  title = {How your colorblind and colorweak readers see your colors -- Datawrapper Blog},
  howpublished = {\url{https://blog.datawrapper.de/colorblindness-part1/}},
  note = {Datawrapper's article explains how different types of colour vision deficiency affect perception. It notes that around 8~% of men of European descent have red-green deficiencies and shows how certain colour combinations are hard to distinguish. The article gives tips for designing charts that are readable for colour-blind readers:contentReference[oaicite:7]\{index=7\}:contentReference[oaicite:8]\{index=8\}.}
}
@misc{susielu_viz_palette,
  title = {Viz Palette -- colour palette design tool},
  howpublished = {\url{https://projects.susielu.com/viz-palette}},
  note = {Viz Palette is an interactive tool for creating and previewing colour palettes for data visualisations. Users can pick and edit colours, view how palettes appear in bar charts or line charts and export palette values. The tool also checks for colour-blind friendliness and displays lightness information:contentReference[oaicite:9]\{index=9\}:contentReference[oaicite:10]\{index=10\}.}
}
@misc{vis4_chromajs_colour,
  title = {Chroma.js Colour Palette Helper},
  howpublished = {\url{https://vis4.net/palettes}},
  note = {The Chroma.js palette helper helps designers build sequential or diverging colour palettes. It allows specifying palette types, arranging input colours and checking lightness. The tool simulates colour vision deficiencies and provides CSS and JSON outputs for use in visualisations:contentReference[oaicite:11]\{index=11\}:contentReference[oaicite:12]\{index=12\}.}
}
@article{alcaraz_martinez_methodology_for_2022,
