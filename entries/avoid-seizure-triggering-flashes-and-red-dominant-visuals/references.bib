@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{umd_photosensitive_epilepsy,
  title = {Photosensitive Epilepsy Analysis Tool (PEAT) User Guide},
  howpublished = {\url{https://trace.umd.edu/photosensitive-epilepsy-analysis-tool-peat-user-guide/}},
  note = {This user guide from the University of Maryland's TRACE Research & Development Center introduces PEAT, a tool that analyses video and multimedia content to detect flashes and patterns that may trigger seizures. It explains how to use the software to scan media for red flashes and rapid flicker and interpret results to minimise seizure risk.}
}
@misc{w3c_understanding_three,
  author = {W3C},
  title = {Understanding Three Flashes or Below Threshold -- WCAG~2.0},
  howpublished = {\url{https://www.w3.org/TR/UNDERSTANDING-WCAG20/seizure.html}},
  note = {The WCAG understanding document for the seizure guideline explains that content should not contain flashes that exceed three per second or red flashes that could trigger seizures. Designers should avoid flickering visuals and high-contrast patterns to protect users with photosensitive epilepsy:contentReference[oaicite:4]\{index=4\}.}
}