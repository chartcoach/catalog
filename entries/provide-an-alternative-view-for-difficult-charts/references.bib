@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{cu-visualab_state_states,
  title = {State of the States IDD Demo -- CU VisualAB},
  howpublished = {\url{http://cu-visualab.org/IDD/demo/}},
  note = {The IDD demo presents an accessible financial dataset about support services for people with intellectual and developmental disabilities. It applies guidelines such as avoiding pie charts, limiting the number of categories and using discrete marks or isotype pictograms in bar charts and scatterplots. The site demonstrates how interactive charts can adapt to different user needs:contentReference[oaicite:55]\{index=55\}:contentReference[oaicite:56]\{index=56\}.}
}
@inproceedings{wu_understanding_data_2021,
  author = {Wu, Keke and Petersen, Emma and Ahmad, Tahmina and Burlinson, David and Tanis, Shea and Szafir, Danielle Albers},
  title = {Understanding Data Accessibility for People with Intellectual and Developmental Disabilities},
  year = {2021},
  booktitle = {Proceedings of the 2021 CHI Conference on Human Factors in Computing Systems},
  publisher = {ACM},
  pages = {1-16},
  doi = {10.1145/3411764.3445743},
  url = {https://doi.org/10.1145/3411764.3445743},
  note = {This research paper explores the design of data visualisation tools for people with intellectual and developmental disabilities (IDD). It proposes alternative chart types such as treemaps with pictograms and simplified scatterplots, and suggests allowing users to switch between visual representations to match their cognitive needs.}
}