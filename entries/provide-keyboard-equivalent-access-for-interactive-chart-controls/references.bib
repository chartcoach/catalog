@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{progressiveaccess_accessible_chemistry,
  title = {Progressive Access: Accessible Chemistry Diagrams},
  howpublished = {\url{https://progressiveaccess.com/chemistry/}},
  note = {The Progressive Access project provides interactive chemical diagrams that are accessible across devices. The site describes features such as keyboard and menu-driven exploration, magnification, high-contrast and different colour schemes. An automated conversion workflow generates accessible SVG diagrams that work with screen readers:contentReference[oaicite:18]\{index=18\}.}
}
@misc{w3c_understanding_keyboard,
  author = {W3C},
  title = {Understanding Keyboard (No Exception) -- WCAG~2.1},
  howpublished = {\url{https://www.w3.org/WAI/WCAG21/Understanding/keyboard-no-exception.html}},
  note = {This WCAG success criterion states that all functionality must be operable using a keyboard without requiring specific timings or multipoint gestures. It ensures that pointer-based interactions have keyboard equivalents and that people who cannot use a mouse can still operate controls:contentReference[oaicite:19]\{index=19\}.}
}