@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{sf_covid19_data_2,
  title = {SF~COVID-19 Data and Reports -- Dashboard Accessibility Information},
  howpublished = {\url{https://sf.gov/resource/2021/covid-19-data-and-reports}},
  note = {San~Francisco's COVID-19 data dashboard provides keyboard instructions for interactive charts. Users press Ctrl+Enter to enter the dashboard, use Tab or arrow keys to navigate between visuals, press Ctrl+$\rightarrow$ to enter a chart or filter, and use Space or Enter to select options. These cues help keyboard and screen reader users interact with the data:contentReference[oaicite:22]\{index=22\}.}
}
@misc{w3c_character_key,
  author = {W3C},
  title = {Character Key Shortcuts (SC~2.1.4) -- WCAG~2.1},
  howpublished = {\url{https://www.w3.org/TR/WCAG21/#character-key-shortcuts}},
  note = {The WCAG specification for character key shortcuts requires that authors provide a way to turn off single-character shortcuts, remap them to include non-printable keys (such as Ctrl or Alt) or ensure they are only active when the target component has focus. This prevents conflicts with screen readers and other assistive technologies:contentReference[oaicite:23]\{index=23\}.}
}