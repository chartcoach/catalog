@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{highcharts_highcharts_accessibility,
  title = {Highcharts Accessibility: Sonification},
  howpublished = {\url{https://www.highcharts.com/docs/accessibility/sonification}},
  note = {Highcharts' accessibility documentation describes a sonification module that turns chart data into audio. Developers can map data values to pitch, duration or timbre and provide keyboard controls to play the chart, giving blind or low-vision users a way to perceive trends and outliers using sound.}
}
@misc{w3c_understanding_info,
  author = {W3C},
  title = {Understanding Info and Relationships -- WCAG~2.1},
  howpublished = {\url{https://www.w3.org/WAI/WCAG21/Understanding/info-and-relationships.html}},
  note = {This guideline emphasises that structural information conveyed visually must also be programmatically determinable. Proper use of headings, lists, table markup and ARIA landmarks allows screen readers to understand relationships and navigate content effectively:contentReference[oaicite:48]\{index=48\}.}
