@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{observablehq_no_use,
  title = {No use of colour alone in data visualization -- Observable},
  howpublished = {\url{https://observablehq.com/@frankelavsky/no-use-of-color-alone-in-data-visualization}},
  note = {This notebook illustrates why colour should not be the only channel for conveying information in charts. It shows examples of scatterplots where categories are encoded using both colour and textures or shapes, demonstrating that adding patterns makes charts accessible to people with colour vision deficiencies.}
}
@misc{w3c_understanding_use,
  author = {W3C},
  title = {Understanding Use of Colour -- WCAG~2.1},
  howpublished = {\url{https://www.w3.org/WAI/WCAG21/Understanding/use-of-color.html}},
  note = {The WCAG guideline on colour use states that colour alone must not convey information, prompt responses or indicate status. Designers should use shapes, patterns, text labels or other visual cues in addition to colour so that people who cannot perceive colour differences can still understand the content:contentReference[oaicite:5]\{index=5\}.}
}