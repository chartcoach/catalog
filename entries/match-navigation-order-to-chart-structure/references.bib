@inproceedings{unknown_accessible_navigation_2015,
  author = {Author, Unknown},
  title = {Accessible Navigation for Hierarchical Data},
  year = {2015},
  booktitle = {Proceedings of the 2015 ACM Conference on Human Factors in Computing Systems},
  publisher = {ACM},
  pages = {1-10},
  doi = {10.1145/2745555.2746667},
  url = {https://doi.org/10.1145/2745555.2746667},
  note = {This CHI paper proposes methods for navigating charts according to data structure rather than linear order. It introduces keyboard and screen reader techniques for exploring hierarchies and nested data, enabling users to move between levels and across siblings in charts like treemaps and grouped bar charts.}
