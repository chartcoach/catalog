@misc{prantl_studying_forthcoming,
 abstract = {Statistical graphs, such as standard bar charts, abstract information in a way that can make it harder for people to efficiently process and interpret the data. Semantic context - linking data to meaningful visual cues - can play a crucial role in improving data experiences. In this work, we introduce Semantic Context Charts, which explicitly integrate semantic context into abstract visualizations to enhance readability and understanding. We created three sets of visualizations drawing on rhetorical principles as design guidelines. Each pairs a standard bar chart with a version enhanced by visual cues to provide semantic context (= Semantic Context Chart) showing the same data. In a mixed-methods study (n = 20) combining interviews and Likert-scale questions, we investigated how semantic context shapes the subjective experience of data visualizations. Our findings show that while Semantic Context Charts (SCC) are preferred for their aesthetic appeal and ability to offer additional information through concrete and relatable visual elements, bar charts were favored for their credibility and trustworthiness. While the measured cognitive load scores showed no clear difference between SCCs and standard bar charts, interview participants described SCCs as enabling quicker, more intuitive information perception. This work advances the discourse on data visualization design by integrating semantic context in the form of visual cues, emphasizing the interplay between aesthetics, cognitive efficiency, and credibility.},
 author = {Prantl, Verena},
 keywords = {Computer Science - Human-Computer Interaction},
 shorttitle = {Studying {Semantic} {Context} in {Visualizations}},
 title = {Studying {Semantic} {Context} in {Visualizations}: {Introducing} {Semantic} {Context} {Charts}}
}