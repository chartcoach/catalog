@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{youtube_accessible_chart,
  title = {Accessible Chart Demonstration (video)},
  howpublished = {\url{https://youtu.be/w6ntxLG6MLQ}},
  note = {This video demonstrates an accessible chart with keyboard navigation and audio description. It shows how all chart information, annotations and trends are exposed to screen readers so that visually impaired users can understand the data without relying on the visual presentation.}
}
@misc{apple_voiceover_user,
  title = {VoiceOver User Guide for Mac -- Apple Support},
  howpublished = {\url{https://support.apple.com/guide/voiceover/welcome/mac}},
  note = {Apple's VoiceOver guide explains how to use the built-in screen reader on macOS. It includes instructions for enabling VoiceOver, navigating with keyboard shortcuts or a braille display and customising voices, helping blind and low-vision users interact with apps and websites.}
}
@misc{nvaccess_home_free,
  title = {NV Access -- Home of the free NVDA screen reader},
  howpublished = {\url{https://www.nvaccess.org/}},
  note = {NV Access is a non-profit organisation that develops NVDA, a free open-source screen reader for Windows. The home page explains that many of the world's 285~million visually impaired people cannot afford commercial screen readers, so NVDA provides speech output and braille support at no cost:contentReference[oaicite:2]\{index=2\}.}
}
@misc{freedomscientific_jaws_screen,
  title = {JAWS Screen Reader -- Freedom Scientific},
  howpublished = {\url{https://www.freedomscientific.com/products/software/jaws/}},
  note = {The JAWS product page describes a widely used Windows screen reader that provides speech and braille output. It lists features such as optical character recognition to read inaccessible text, multiple synthesiser options and keyboard commands to navigate documents, web pages and applications:contentReference[oaicite:3]\{index=3\}.}
}
@misc{google_use_talkback,
  title = {Use TalkBack screen reader on Android -- Google Accessibility},
  howpublished = {\url{https://support.google.com/accessibility/android/answer/6283677?hl=en}},
  note = {Google's support page explains how to turn on and use TalkBack, the built-in screen reader on Android devices. It covers enabling TalkBack in settings, using gestures and keyboard shortcuts to explore by touch and configuring speech feedback, helping users who are blind or low-vision to operate their phones.}
}
@misc{w3c_wcag_quick,
  author = {W3C},
  title = {WCAG~Quick Reference -- Text Alternatives},
  howpublished = {\url{https://www.w3.org/WAI/WCAG21/quickref/#text-alternatives}},
  note = {The WCAG quick reference summarises requirements for text alternatives. It states that non-text content, such as images or charts, must have text descriptions so that information can be presented in alternative modalities like screen readers or braille.}
}