@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{observablehq_chart_component,
  title = {Chart Component Boilerplate -- Observable},
  howpublished = {\url{https://observablehq.com/@frankelavsky/chart-component-boilerplate}},
  note = {This Observable notebook provides a template for building accessible chart components. It includes code examples showing how to implement keyboard navigation, set tab order, manage focus and apply ARIA attributes so that complex charts can be explored using a keyboard:contentReference[oaicite:28]\{index=28\}.}
}
@misc{w3c_understanding_focus_order,
  author = {W3C},
  title = {Understanding Focus Order -- WCAG~2.1},
  howpublished = {\url{https://www.w3.org/WAI/WCAG21/Understanding/focus-order.html}},
  note = {WCAG's focus order criterion requires that interactive elements receive focus in an order that preserves meaning and operability. Keyboard users should encounter content in a logical sequence, such as row-by-row or left-to-right, so that navigation is predictable:contentReference[oaicite:29]\{index=29\}.}
}