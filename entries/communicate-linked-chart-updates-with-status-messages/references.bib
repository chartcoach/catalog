  note = {The status messages guideline requires that important updates or changes in content be programmatically conveyed to assistive technologies. This allows screen readers to announce updates like form submission results or dynamic alerts without shifting focus, keeping users informed:contentReference[oaicite:36]\{index=36\}.}
