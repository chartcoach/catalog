  author = {Baber, C. and Stanton, N. A.},
  title = {Task analysis for error identification: a methodology for designing error-tolerant consumer products},
  year = {1994},
  journal = {Ergonomics},
  publisher = {Informa UK Limited},
  volume = {37},
  number = {11},
  pages = {1923-1941},
  doi = {10.1080/00140139408964958},
  url = {https://doi.org/10.1080/00140139408964958},
  note = {This human factors study discusses the importance of making interactive systems forgiving of mistakes. It recommends providing undo and redo features, confirmation prompts and ways to recover from errors, acknowledging that users will make mistakes and that interfaces should be designed to tolerate them.}
}