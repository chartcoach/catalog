@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{inclusivedesignprinciples_give_control,
  title = {Give Control -- Inclusive Design Principles},
  howpublished = {\url{https://inclusivedesignprinciples.org/#give-control}},
  note = {The 'Give Control' principle recommends giving users the ability to pause, stop or adjust long-running animations and to turn off features like infinite scrolling. Allowing users to control how content changes makes experiences more accessible and reduces motion sickness and cognitive load.}
}