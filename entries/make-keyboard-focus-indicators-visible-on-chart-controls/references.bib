@article{elavskyHowAccessibleMy2022,
 annote = {Concrete set of visualization design guidelines about chart accessibility. Minor overlap with Talking Chart guidelines. 
Chartability has evaluated static and interactive data experiences made with Microsoft’s Excel and PowerBI, Tableau, JavaScript (D3, Vega-Lite, Highcharts, Visa Chart Components), Python (Altair, Bokeh, and matplotlib), R (ggplot2), as well as design sketches and low/medium-fidelity artifacts (Illustrator, Figma, Sketch).
--{\textgreater} from a modeling perspective this is interesting as there are concrete examples of guidelines getting applied to visualizations represented across different formats, media \& grammars.},
 author = {Elavsky, Frank and Bennett, Cynthia and Moritz, Dominik},
 doi = {10.1111/cgf.14522},
 issn = {0167-7055, 1467-8659},
 journal = {Computer Graphics Forum},
 language = {en},
 month = {June},
 number = {3},
 pages = {57--70},
 shorttitle = {How accessible is my visualization?},
 title = {How accessible is my visualization? {Evaluating} visualization accessibility with {Chartability}},
 url = {https://onlinelibrary.wiley.com/doi/10.1111/cgf.14522},
 urldate = {2025-10-05},
 volume = {41},
 year = {2022}
}

@misc{github_visa_chart_2,
  title = {Visa Chart Components -- Utils: Interactivity},
  howpublished = {\url{https://github.com/visa/visa-chart-components/tree/main/packages/utils#interactivity}},
  note = {The Visa Chart Components utils library includes functions for accessible interactivity. `setElementFocusHandler` adds focus listeners to highlight elements when navigating via keyboard; `setElementInteractionAccessState` toggles interactive elements to semantic buttons; and `setElementAccessID` assigns unique IDs to tie elements to ARIA properties. These utilities help developers create chart components that meet keyboard and screen reader requirements:contentReference[oaicite:26]\{index=26\}.}
}
@misc{w3c_understanding_focus,
  author = {W3C},
  title = {Understanding Focus Appearance (Minimum) -- WCAG~2.2},
  howpublished = {\url{https://www.w3.org/WAI/WCAG22/Understanding/focus-appearance-minimum.html}},
  note = {The focus appearance criterion requires that keyboard focus indicators be large enough and contrast sufficiently with the unfocused state. Specifically, the focus indicator must cover an area at least as large as a 2~CSS-pixel border around the element and have a contrast ratio of at least 3~:1, helping users locate the current focus:contentReference[oaicite:27]\{index=27\}.}
}